# Azure AI Foundry configuration
# Copy this file to .env and fill in your values.
#
# The project endpoint is found in your Azure AI Foundry project settings.
# Format: https://<your-resource>.services.ai.azure.com/api/projects/<project-id>
AZURE_AI_PROJECT_ENDPOINT=https://<your-resource>.services.ai.azure.com/api/projects/<project-id>

# The model deployment name from your Foundry project's model catalog.
# Examples: mistral-large, gpt-4o, DeepSeek-R1, Meta-Llama-3-70B
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o
